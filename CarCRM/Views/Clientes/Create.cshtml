@model CarCRM.Models.Cliente

@{
    ViewData["Title"] = "Create";
}

<h1>Criar</h1>

<h4>Cliente</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Create">
            <div class="form-group">
                <label class="control-label">Pessoa</label>
                <select name="tipoPessoa" id="tipoPessoa" class="form-control">
                    <option value="">Selecione </option>>
                    <option value="pessoaFisica">Pessoa Física</option>>
                    <option value="pessoaJuridica">Pessoa Jurídica</option>>
                </select>                
            </div>

            <div class="form-group">
                <label class="control-label">Nome</label>
                <input name="nome" class="form-control" />
            </div>

            <div class="form-group">
                <label class="control-label">Email</label>
                <input name="email" class="form-control" />
            </div>

            <div id="camposPF" style="display:none;">
                <div class="form-group">
                    <label class="control-label">CPF</label>
                    <input name="cpf" class="form-control" />
                </div>

                <div class="form-group">
                    <label class="control-label">RG</label>
                    <input name="rg" class="form-control" />
                </div>
                <div class="form-group">
                    <label class="control-label">Data de Nascimento</label>
                    <input name="dataNascimento" type="date" class="form-control" />
                </div>
            </div>
            <div id="camposPJ" style="display:none;">
                <div class="form-group">
                    <label class="control-label">CNPJ</label>
                    <input name="cnpj" class="form-control"/>
                </div>

                <div class="form-group">
                    <label class="control-label">Razao Social</label>
                    <input name="razaoSocial" class="form-control"/>
                </div>

                <div class="form-group">
                    <label class="control-label">Nome Fantasia</label>
                    <input  name="nomeFantasia" class="form-control"/>
                </div>

                <div class="form-group">
                    <label class="control-label">Nome Interno</label>
                    <input name="nomeInterno" class="form-control" />
                </div>
            </div>
            <div class="form-group">
                <label class="control-label">Excluido</label>
                <input name="excluido" type="checkbox" value="false" class="form-check-input" />
            </div>
            <br />
            <hr />
            <div class="form-group ">
                <h4>Telefone</h4>
                <div style="display: flex; align-items: flex-end; gap: 10px;" >
                    <div>
                        <label class="control-label">Tipo</label>
                        @Html.DropDownList("telefonetipoId",
                        new SelectList(ViewBag.telefonesTipo, "Id", "Nome"),
                        new { @class = "form-control" })
                    </div>
                    <div style="width: 80px">
                        <label class="control-label">DDD</label>
                        <input name="ddd" class="form-control"/> 
                    </div>
                    <div style="flex: 1;">
                        <label class="control-label">Número</label>
                        <input name="numero" class="form-control" />
                    </div>
            </div>
        </div>
            <br />
            <div class="form-group">
                <input type="submit" value="Criar" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index">Voltar</a>
</div>

@section Scripts {

<script>
    function alterarCampos() {
        var tipo = $("#tipoPessoa").val();

        if (tipo == "pessoaFisica") {
            $("#camposPF").show();
            $("#camposPJ").hide();
        }
        else if(tipo == "pessoaJuridica") {
            $("#camposPF").hide();
            $("#camposPJ").show();
        }
        else {
            $("#camposPF").hide();
            $("#camposPJ").hide();
        }
    }   
    
    $(document).ready(function () {

        alterarCampos();

        $("#tipoPessoa").change(function () {
            alterarCampos();
        });
    });
</script>

}