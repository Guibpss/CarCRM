@model CarCRM.Models.Cliente

@{
    ViewData["Title"] = "Edit";
    var pf = Model.Pessoa as CarCRM.Models.PessoaFisica;
    var pj = Model.Pessoa as CarCRM.Models.PessoaJuridica;
    var telefone = Model.Pessoa?.Telefones?.FirstOrDefault();
}

<h1>Editar</h1>

<h4>Cliente</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Edit">
            <input type="hidden" name="id" value="@Model.Id" />        
            <div class="form-group">
                <label class="control-label">Nome</label>
                <input name="nome" value="@Model.Pessoa.Nome" class="form-control" />
            </div>
            <div>
                <label class="control-label">Tipo</label>

            </div>
            <div>
                <label class="control-label">Email</label>
                <input name="email" value="@Model.Pessoa.Email" class="form-control" />
            </div>
            <div id="camposPF" style="display:@(pf != null ? "block" : "none");">
                <div class="form-group">
                    <label class="control-label">CPF</label>
                    <input name="cpf" value="@pf?.CPF" class="form-control" />
                </div>

                <div class="form-group">
                    <label class="control-label">RG</label>
                    <input name="rg" value="@pf?.RG" class="form-control" />
                </div>
                <div class="form-group">
                    <label class="control-label">Data de Nascimento</label>
                    <input name="dataNascimento" value="@pf?.DataNascimento.ToString("dd/MM/yyyy")" type="date" class="form-control" />
                </div>
            </div>
            <div id="camposPJ" style="display:@(pj != null ? "block" : "none");">
                <div class="form-group">
                    <label class="control-label">CNPJ</label>
                    <input name="cnpj" value="@pj?.CNPJ" class="form-control" />
                </div>

                <div class="form-group">
                    <label class="control-label">Razao Social</label>
                    <input name="razaoSocial" value="@pj?.RazaoSocial" class="form-control" />
                </div>

                <div class="form-group">
                    <label class="control-label">Nome Fantasia</label>
                    <input name="nomeFantasia" value="@pj?.NomeFantasia" class="form-control" />
                </div>

                <div class="form-group">
                    <label class="control-label">Nome Interno</label>
                    <input name="nomeInterno" value="@pj?.NomeInterno" class="form-control" />
                </div>
            </div>

            <div class="form-group">
                <label class="control-label">Excluido</label>
                <input name="excluido" type="checkbox" value="true" class="form-check-input" @(Model.Excluido ? "checked" : "") />
            </div>
            <div>
                <br />
                <h4>Telefone</h4>
                <hr />
                <div style="display: flex; align-items: flex-end; gap: 10px;">
                    <div>
                        <label class="control-label">Tipo</label>
                        @Html.DropDownList("telefonetipoId",
                        new SelectList(ViewBag.telefonesTipo, "Id", "Nome", telefone?.TelefoneTipoId),
                        new { @class = "form-control" })
                    </div>
                </div>
                <div style="width: 80px;">
                    <label class="control-label">DDD</label>
                    <input name="ddd" value="@telefone?.DDD" class="form-control" />
                </div>
                <div style="flex: 1;">
                    <label class="control-label">Número</label>
                    <input name="numero"  value="@telefone?.Numero" class="form-control" />
                </div>
            </div>
            <br />
            <div class="form-group">
                <input type="submit" value="Salvar" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index">Voltar</a>
</div>

@section Scripts {
   
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
