@model CarCRM.Models.Usuario

@{
    ViewData["Title"] = "Delete";
}

<h1>Excluir</h1>

<h3>Tem certeza que deseja excluir?</h3>
<div>
    <h4>Usuario</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">
            Nome
        </dt>
        <dd class="col-sm-10">
            @Model.Nome
        </dd>

        <dt class="col-sm-2">
            CPF
        </dt>
        <dd class="col-sm-10">
            @Model.Pessoa.CPF
        </dd>

        <dt class="col-sm-2">
            RG
        </dt>
        <dd class="col-sm-10">
            @Model.Pessoa.RG
        </dd>

        <dt class="col-sm-2">
            Data de Nascimento
        </dt>
        <dd class="col-sm-10">
            @Model.Pessoa.DataNascimento.ToString("dd/MM/yyyy")
        </dd>

        <dt class="col-sm-2">
            Email
        </dt>
        <dd class="col-sm-10">
            @Model.Pessoa.Email
        </dd>

        <dt class="col-sm-2">
            Ativo
        </dt>
        <dd class="col-sm-10">
            @(Model.Ativo ? "Sim" : "Não")
        </dd>

        <dt class="col-sm-2">
            Perfil
        </dt>
        <dd class="col-sm-10">
            @Model.Perfil?.Nome
        </dd>

        <dt class="col-sm-2">
            Criado Em
        </dt>
        <dd class="col-sm-10">
            @Model.CriadoEm
        </dd>
    </dl>
    <form asp-action="Delete">
        <input type="hidden" asp-for="Id" />
        <input type="submit" value="Excluir" class="btn btn-danger" /> |
        <a asp-action="Index">Voltar</a>
    </form>
</div>
