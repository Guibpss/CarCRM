@model CarCRM.Models.Usuario

@{
   
    ViewData["Title"] = "Create";
}

<h1>Criar</h1>
<h4>Usuario</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Create">

            <div class="form-group">
                <label class="control-label">Nome</label>
                <input name="nome" class="form-control" required />
            </div>

            <div class="form-group">
                <label class="control-label">CPF</label>
                <input name="cpf" class="form-control" required />
            </div>

            <div class="form-group">
                <label class="control-label">RG</label>
                <input name="rg" class="form-control" required />
            </div>

            <div class="form-group">
                <label class="control-label">Data de Nascimento</label>
                <input name="dataNascimento" type="date" class="form-control" required />
            </div>

            <div class="form-group">
                <label class="control-label">Email</label>
                <input name="email" class="form-control" required />
            </div>

            <div class="form-group">
                <label class="control-label">Ativo</label>
                <input name="ativo" type="checkbox" value="true" class="form-check-input" />
            </div>

            <div class="form-group">
                <label class="control-label">Perfil</label>
                @Html.DropDownList("perfilId",
                    new SelectList(ViewBag.Perfis, "Id", "Nome"),
                    new { @class = "form-control", required = "required" })
            </div>

            <div class="form-group">
                <input type="submit" value="Criar" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index">Voltar</a>
</div>
