@model CarCRM.Models.Estoque

@{
    ViewData["Title"] = "Details";
}

<h1>Detalhes</h1>

<div>
    <h4>Estoque</h4>
    <hr />
    <dl>
        <dt class = "col-sm-2">
            nome
        </dt>
        <dd class = "col-sm-10">
            @Model.Nome
        </dd>
    </dl>
        <dt class = "col-sm-2">
            Data de Entrada
        </dt>
        <dd class = "col-sm-10">
            @Model.DataEntrada.ToString("dd/MM/yyyy")
        </dd>
    </dl>
        <dt class = "col-sm-2">
            Excluido
        </dt>
        <dd class = "col-sm-10">
            @Model.Excluido
        </dd>
    </dl>
</div>
<div>
    <a asp-action="Edit" asp-route-id="@Model?.Id">Editar</a> |
    <a asp-action="Index">Voltar</a>
</div>
