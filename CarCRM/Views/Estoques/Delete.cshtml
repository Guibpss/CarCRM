@model CarCRM.Models.Estoque

@{
    ViewData["Title"] = "Delete";
}

<h1>Excluir</h1>

<h3>Tem certeza que deseja excluir?</h3>
<div>
    <h4>Estoque</h4>
    <hr />
    <dl>
        <dt class = "col-sm-2">
            Nome
        </dt>
        <dd class = "col-sm-10">
            @Model.Nome
        </dd>
        <dt class = "col-sm-2">
            Data de Entrada
        </dt>
        <dd class = "col-sm-10">
            @Model.DataEntrada.ToString("dd/MM/yyyy")
        </dd>
        <dt class = "col-sm-2">
            Excluido
        </dt>
        <dd class = "col-sm-10">
            @(Model.Excluido ? "Sim" : "Não")
        </dd>
        <dt class="col-sm-2">
            Criado Em
        </dt>
        <dd class="col-sm-10">
            @Model.CriadoEm
        </dd>
    </dl>
    <form asp-action="Delete">
        <input type="hidden" asp-for="Id" />
        <input type="submit" value="Excluir" class="btn btn-danger" /> |
        <a asp-action="Index">Voltar</a>
    </form>
</div>
